# Database Configuration (PostgreSQL)
# Get your connection string from your PostgreSQL provider
# Example: postgresql://user:password@localhost:5432/mediscan
DATABASE_URL=postgresql://user:password@host:5432/database

# Authentication Configuration (Optional)
# Better Auth will auto-detect Vercel URLs, but you can override if needed
BETTER_AUTH_URL=https://your-domain.com

# API Keys for AI Features (if using external APIs)
# Add any third-party API keys here
