# Database Configuration (PostgreSQL)
# Get your connection string from your PostgreSQL provider
# Example: postgresql://user:password@localhost:5432/mediscan
DATABASE_URL=postgresql://user:password@host:5432/database

# Authentication Configuration
# For production: Generate a secure secret using: openssl rand -base64 32
# For development: A random secret will be generated automatically if not set
BETTER_AUTH_SECRET=your-secret-key-here-min-32-chars-long

# Optional: Custom auth URL (auto-detected on Vercel if not set)
BETTER_AUTH_URL=https://your-domain.com

# API Keys for AI Features (if using external APIs)
# Add any third-party API keys here

